<Window x:Class="TodoFloat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TodoFloat.ViewModels"
        xmlns:ctl="clr-namespace:TodoFloat.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="TodoFloat"
        Width="{StaticResource WindowWidth}" Height="{StaticResource WindowHeight}"
        MinWidth="360" MinHeight="380"
        Background="{DynamicResource GlassBrush}"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResize"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="6"
                            CaptionHeight="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Style="{StaticResource AppWindowShell}">
        <AdornerDecorator>
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶栏一行搞定：tabs + 动作图标 + Win11 控制按钮 -->
            <Grid x:Name="DragBar"
                  Grid.Row="0"
                  Background="Transparent"
                  Cursor="SizeAll">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid x:Name="TopTabHostSlot"
                      Grid.Column="0"
                      Margin="12,3,6,3"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Stretch">
                    <Border Style="{StaticResource SegmentedShell}"
                            MaxWidth="{Binding ActualWidth, ElementName=TopTabHostSlot}"
                            HorizontalAlignment="Left">
                        <StackPanel x:Name="TopTabGrid" Orientation="Horizontal" ClipToBounds="True">
                            <ToggleButton x:Name="TodayTab"
                                          Style="{StaticResource SegmentedToggleButton}"
                                          IsChecked="{Binding IsTodayView, Mode=TwoWay}"
                                          ToolTip="待办"
                                          AutomationProperties.Name="待办"
                                          Tag="Today"
                                          Click="TopTab_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TodayTabLabel" Text="待办" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="TodayCountText"
                                               Text="{Binding TodayCount}"
                                               Margin="5,0,0,0"
                                               Opacity="0.75"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton x:Name="UpcomingTab"
                                          Style="{StaticResource SegmentedToggleButton}"
                                          IsChecked="{Binding IsUpcomingView, Mode=TwoWay}"
                                          ToolTip="规划"
                                          AutomationProperties.Name="规划"
                                          Tag="Upcoming"
                                          Click="TopTab_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="UpcomingTabLabel" Text="规划" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="UpcomingCountText"
                                               Text="{Binding UpcomingCount}"
                                               Margin="5,0,0,0"
                                               Opacity="0.75"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton x:Name="InboxTab"
                                          Style="{StaticResource SegmentedToggleButton}"
                                          IsChecked="{Binding IsInboxView, Mode=TwoWay}"
                                          ToolTip="全部待办"
                                          AutomationProperties.Name="全部"
                                          Tag="Inbox"
                                          Click="TopTab_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="InboxTabLabel" Text="全部" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="InboxCountText"
                                               Text="{Binding InboxCount}"
                                               Margin="5,0,0,0"
                                               Opacity="0.75"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton x:Name="CompletedTab"
                                          Style="{StaticResource SegmentedToggleButton}"
                                          IsChecked="{Binding IsCompletedView, Mode=TwoWay}"
                                          ToolTip="已完成"
                                          AutomationProperties.Name="完成"
                                          Tag="Completed"
                                          Click="TopTab_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock x:Name="CompletedTabLabel" Text="完成" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="CompletedCountText"
                                               Text="{Binding CompletedCount}"
                                               Margin="5,0,0,0"
                                               Opacity="0.75"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 中间空白列：拖拽区 -->

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button x:Name="SearchButton"
                            Content="&#xE721;"
                            ToolTip="搜索"
                            Click="BtnSearch_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TitleIconButton}">
                                <Style.Triggers>
                                    <!-- 搜索模式开启时：图标变主色，提示当前是搜索状态 -->
                                    <DataTrigger Binding="{Binding IsSearchMode}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentInkBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource TitleIconButton}"
                            Content="&#xE713;"
                            ToolTip="设置"
                            Click="BtnSettings_Click">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="桌面宠物"
                                          IsCheckable="True"
                                          IsChecked="{Binding AutoHideEnabled}"
                                          Command="{Binding ToggleAutoHideCommand}"/>
                                <MenuItem Header="检查更新…" Click="MenuCheckUpdates_Click"/>
                                <MenuItem Header="查看版本…" Click="MenuShowVersion_Click"/>
                                <MenuItem Header="查看版本公告…" Click="MenuShowVersionAnnouncement_Click"/>
                                <MenuItem Header="数据存储位置…" Click="MenuDataStorage_Click"/>
                                <Separator/>
                                <MenuItem Header="分类管理…" Click="MenuCategories_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Style="{StaticResource CaptionButton}"
                            Content="&#xE921;"
                            ToolTip="最小化"
                            Click="BtnMinimize_Click"/>
                    <Button Style="{StaticResource CaptionCloseButton}"
                            Content="&#xE8BB;"
                            ToolTip="关闭"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="16,8,16,0">
                <Border x:Name="NewTaskRow"
                        Style="{StaticResource QuickAddShell}"
                        Margin="0,14,0,0"
                        MouseLeftButtonDown="NewTaskRow_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- ====== 左侧图标：添加态 = 虚线圆+号；搜索态 = 放大镜 ====== -->
                        <Grid Grid.Column="0">
                            <Button x:Name="QuickAddButton"
                                    Width="28"
                                    Height="28"
                                    VerticalAlignment="Center"
                                    Click="QuickAddButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <!-- Hidden 而非 Collapsed：保留 28px 高度，避免卡片整体变矮、下方任务列表错位 -->
                                            <DataTrigger Binding="{Binding IsSearchMode}" Value="True">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Ellipse x:Name="Circle"
                                                     Width="22"
                                                     Height="22"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Stroke="{StaticResource MutedBrush}"
                                                     StrokeThickness="0.9"
                                                     StrokeDashArray="2.4 2.0"
                                                     StrokeDashCap="Round"
                                                     Fill="Transparent"/>
                                            <Path Data="M 0,5 L 10,5 M 5,0 L 5,10"
                                                  Stroke="{StaticResource MutedBrush}"
                                                  StrokeThickness="1.3"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Width="10" Height="10"
                                                  Stretch="None"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Grid>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearchMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- ====== 中间输入区：单 TextBox，占位文字按 IsSearchMode 切换 ====== -->
                        <Grid Grid.Column="1" Margin="8,0,8,0">
                            <TextBox x:Name="NewTaskBox"
                                     Text="{Binding QuickInput, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="NewTaskBox_KeyDown"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="Text" Value="添加任务"/>
                                        <Style.Triggers>
                                            <!-- 输入框为空就显示，根据 IsSearchMode 切换文案 -->
                                            <DataTrigger Binding="{Binding QuickInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSearchMode}" Value="True">
                                                <Setter Property="Text" Value="搜索任务..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- ====== 右侧图标：搜索态用 Hidden 隐藏（保留列宽，TextBox 不重排） ====== -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSearchMode}" Value="True">
                                            <Setter Property="Visibility" Value="Hidden"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Button Style="{StaticResource GlyphButton}"
                                    Width="22" Height="22"
                                    Content="&#xE787;"
                                    Margin="0,0,2,0"
                                    ToolTip="日期与时间"
                                    Click="QuickDueButton_Click"/>
                            <Button Style="{StaticResource GlyphButton}"
                                    Width="22" Height="22"
                                    Content="&#xE7C1;"
                                    Margin="0,0,2,0"
                                    ToolTip="优先级"
                                    Click="QuickPriorityButton_Click"/>
                            <Button Style="{StaticResource GlyphButton}"
                                    Width="22" Height="22"
                                    Content="&#xE8EC;"
                                    Margin="0,0,4,0"
                                    Click="QuickTagButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <WrapPanel Margin="0,8,0,0">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasQuickChips}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSearchMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>

                    <Border Margin="0,0,6,4">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Pill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QuickChipDueLabel}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding QuickChipDueLabel}"
                                       Foreground="{StaticResource TextBrush2}"
                                       FontSize="11.5"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource ChipCloseButton}"
                                    Command="{Binding ClearDueChipCmdCommand}"
                                    Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,6,4">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Pill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QuickChipPriorityLabel}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C1;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{Binding QuickChipPriorityBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding QuickChipPriorityLabel}"
                                       Foreground="{StaticResource TextBrush2}"
                                       FontSize="11.5"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource ChipCloseButton}"
                                    Command="{Binding ClearPriorityChipCmdCommand}"
                                    Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,6,4">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Pill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QuickChipCategoryName}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     Fill="{Binding QuickChipCategoryBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding QuickChipCategoryName}"
                                       Foreground="{StaticResource TextBrush2}"
                                       FontSize="11.5"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource ChipCloseButton}"
                                    Command="{Binding ClearCategoryChipCmdCommand}"
                                    Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- 搜索栏已并入 NewTaskRow 上方共用 — 通过 IsSearchMode 切换可见的 TextBox / 图标 -->

            </StackPanel>

            <ScrollViewer x:Name="MainScroller"
                          Grid.Row="2"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,10,12,8">
                <!-- MinHeight 绑到 viewport，让空状态可在视口内垂直居中 -->
                <Grid MinHeight="{Binding ViewportHeight, ElementName=MainScroller}">
                    <ItemsControl ItemsSource="{Binding TaskGroups}"
                                  FocusVisualStyle="{x:Null}"
                                  Focusable="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TaskGroupViewModel}">
                                <StackPanel Margin="0,0,0,14">
                                    <Grid Margin="6,2,6,4"
                                          Visibility="{Binding ShowHeader, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="11.5"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush2}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAccent}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentInkBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Subtitle, StringFormat=' · {0}'}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="11.5"
                                                   Margin="8,0,0,0"/>
                                    </Grid>

                                    <Border Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="12"
                                            ClipToBounds="False">
                                        <ItemsControl ItemsSource="{Binding Tasks}"
                                                      FocusVisualStyle="{x:Null}"
                                                      Focusable="False">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                                                    <StackPanel x:Name="TaskCard"
                                                                Tag="{Binding}"
                                                                Margin="0,0,0,6">
                                                        <Border x:Name="TaskRow"
                                                                Tag="{Binding}"
                                                                PreviewMouseLeftButtonDown="TaskRow_PreviewMouseLeftButtonDown"
                                                                PreviewMouseMove="TaskRow_PreviewMouseMove"
                                                                MouseLeftButtonUp="TaskRow_LeftClick">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource TaskRow}">
                                                                    <Setter Property="CornerRadius" Value="12"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                                            <Setter Property="BorderThickness" Value="0"/>
                                                                            <Setter Property="CornerRadius" Value="12,12,0,0"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsAnimating, ElementName=ExpandHost}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                                            <Setter Property="BorderThickness" Value="0"/>
                                                                            <Setter Property="CornerRadius" Value="12,12,0,0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="22"/>
                                                                    <ColumnDefinition Width="14"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="24"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Border Grid.ColumnSpan="5"
                                                                        Width="2.5"
                                                                        HorizontalAlignment="Left"
                                                                        Margin="-6,2,0,0"
                                                                        Background="{StaticResource AccentBrush}"
                                                                        CornerRadius="0,3,3,0"
                                                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"/>

                                                                <UniformGrid Rows="3"
                                                                             Columns="2"
                                                                             Width="8"
                                                                             Height="16"
                                                                             HorizontalAlignment="Left"
                                                                             VerticalAlignment="Center"
                                                                             Margin="0,0,0,0">
                                                                    <UniformGrid.Style>
                                                                        <Style TargetType="UniformGrid">
                                                                            <Setter Property="Opacity" Value="0"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                                    <Setter Property="Opacity" Value="0.55"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </UniformGrid.Style>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                </UniformGrid>

                                                                <CheckBox Grid.Column="1"
                                                                          Style="{StaticResource RoundCheckBox}"
                                                                          Width="14" Height="14"
                                                                          Margin="0,3,0,0"
                                                                          IsChecked="{Binding Completed, Mode=OneWay}"
                                                                          Tag="{Binding PriorityKey}"
                                                                          Click="CompleteCheckbox_Click"
                                                                          VerticalAlignment="Top"/>

                                                                <StackPanel Grid.Column="2" Margin="10,0,8,0">
                                                                    <Grid>
                                                                        <TextBlock x:Name="TaskTitleText"
                                                                                   Text="{Binding Title}"
                                                                                   Cursor="Arrow"
                                                                                   MouseLeftButtonDown="TaskTitle_MouseLeftButtonDown">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TaskTitleText}">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Completed}" Value="True">
                                                                                            <Setter Property="TextDecorations" Value="{StaticResource StrikethroughCentered}"/>
                                                                                            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsInlineEditing}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBox Text="{Binding EditingTitle, UpdateSourceTrigger=PropertyChanged}"
                                                                                 FontSize="14"
                                                                                 FontWeight="SemiBold"
                                                                                 Padding="2,0"
                                                                                 BorderThickness="0"
                                                                                 Background="Transparent"
                                                                                 VerticalContentAlignment="Center"
                                                                                 KeyDown="SubtaskEdit_KeyDown"
                                                                                 LostFocus="SubtaskEdit_LostFocus"
                                                                                 IsVisibleChanged="SubtaskEdit_IsVisibleChanged">
                                                                            <TextBox.Style>
                                                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsInlineEditing}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBox.Style>
                                                                        </TextBox>
                                                                    </Grid>

                                                                    <!-- Title 下的 meta 摘要：仅折叠态显示；展开后由 chip 区接管，避免重复 -->
                                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                        <StackPanel.Style>
                                                                            <Style TargetType="StackPanel">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsAnimating, ElementName=ExpandHost}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsInlineEditing}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </StackPanel.Style>
                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                                                            <StackPanel.Style>
                                                                                <Style TargetType="StackPanel">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding CategoryName}" Value="{x:Null}">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </StackPanel.Style>
                                                                            <Ellipse Width="7" Height="7"
                                                                                     Fill="{Binding CategoryBrush}"
                                                                                     VerticalAlignment="Center"
                                                                                     Margin="0,0,4,0"/>
                                                                            <TextBlock Text="{Binding CategoryName}" Style="{StaticResource MetaText}"/>
                                                                        </StackPanel>

                                                                        <TextBlock Text="{Binding DueLabel}" Margin="0,0,8,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MetaText}">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding DueLabel}" Value="">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>

                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,8,0"
                                                                                    VerticalAlignment="Center">
                                                                            <StackPanel.Style>
                                                                                <Style TargetType="StackPanel">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasSubtasks}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </StackPanel.Style>
                                                                            <ProgressBar Style="{StaticResource WindowProgress}"
                                                                                         Width="44"
                                                                                         Height="4"
                                                                                         Value="{Binding SubtaskProgress, Mode=OneWay}"
                                                                                         VerticalAlignment="Center"
                                                                                         Margin="0,0,6,0"/>
                                                                            <TextBlock Text="{Binding SubtaskSummary}"
                                                                                       Style="{StaticResource MetaText}"
                                                                                       VerticalAlignment="Center"/>
                                                                        </StackPanel>

                                                                    </StackPanel>
                                                                </StackPanel>

                                                                <!-- 右侧优先级旗：使用固定槽位 + Path，避免字体 glyph 的 baseline 偏移。 -->
                                                                <Grid Grid.Column="3"
                                                                      Width="18"
                                                                      Height="18"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Top">
                                                                    <Grid.Style>
                                                                        <Style TargetType="Grid">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding PriorityKey}" Value="none">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Grid.Style>
                                                                    <Path Width="12"
                                                                          Height="12"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          Data="M 2.5 1.5 L 2.5 11 M 3 2.2 C 4.8 1.3 6.2 2.9 8 2.1 C 9.2 1.6 10.2 1.9 11 2.4 L 11 7.4 C 9.9 6.9 8.8 6.7 7.6 7.2 C 5.8 8 4.4 6.3 2.5 7.2"
                                                                          Stretch="Fill"
                                                                          Stroke="{Binding PriorityBrush}"
                                                                          StrokeThickness="1.35"
                                                                          StrokeStartLineCap="Round"
                                                                          StrokeEndLineCap="Round"
                                                                          StrokeLineJoin="Round"/>
                                                                </Grid>

                                                                <Button Grid.Column="4"
                                                                        Width="20"
                                                                        Height="20"
                                                                        FontSize="10"
                                                                        Content="&#xE74D;"
                                                                        ToolTip="删除"
                                                                        VerticalAlignment="Top"
                                                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource GlyphButton}">
                                                                            <Setter Property="Opacity" Value="0"/>
                                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=TaskRow}" Value="True">
                                                                                    <Setter Property="Opacity" Value="1"/>
                                                                                    <Setter Property="IsHitTestVisible" Value="True"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </Grid>
                                                        </Border>

                                                        <ctl:AnimatedExpander x:Name="ExpandHost"
                                                                              IsExpanded="{Binding IsExpanded}"
                                                                              ExpandDuration="0:0:0.34"
                                                                              CollapseDuration="0:0:0.17"
                                                                              FocusVisualStyle="{x:Null}"
                                                                              Focusable="False"
                                                                              IsHitTestVisible="{Binding IsExpanded}"
                                                                              SnapsToDevicePixels="True">
                                                        <Border x:Name="ExpandPane"
                                                                Background="{StaticResource AccentSoftBrush}"
                                                                BorderBrush="{StaticResource Line2Brush}"
                                                                BorderThickness="0,1,0,0"
                                                                CornerRadius="{Binding DetailCornerRadius}"
                                                                Padding="0"
                                                                FocusVisualStyle="{x:Null}"
                                                                Focusable="False"
                                                                Opacity="0"
                                                                RenderTransformOrigin="0.5,0">
                                                            <Border.RenderTransform>
                                                                <TranslateTransform x:Name="ExpandContentShift" Y="-4"/>
                                                            </Border.RenderTransform>
                                                            <Grid>
                                                                <StackPanel Margin="46,7,14,12">
                                                                <Grid Margin="0,0,0,8">
                                                                    <WrapPanel>
                                                                        <!-- ====== 已存在的 chip：先排在前面 ====== -->
                                                                        <!-- 日期 chip：hover 显 × 删除；DueLabel 为空时整体隐藏 -->
                                                                        <Border x:Name="ChipDateBorder"
                                                                                Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipDate_Click">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                                                                           Foreground="{StaticResource MutedBrush}" FontSize="11"
                                                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                                <TextBlock Text="{Binding DueLabel}" Foreground="{StaticResource TextBrush2}" FontSize="11.5"
                                                                                           VerticalAlignment="Center"/>
                                                                                <Button Style="{StaticResource ChipCloseButton}"
                                                                                        Click="ChipDateRemove_Click"
                                                                                        Margin="6,0,0,0"
                                                                                        Visibility="{Binding IsMouseOver, ElementName=ChipDateBorder, Converter={StaticResource BoolToVisibility}}"/>
                                                                            </StackPanel>
                                                                            <Border.Style>
                                                                                <Style TargetType="Border" BasedOn="{StaticResource ClickablePill}">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding DueLabel}" Value="">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                        </Border>

                                                                        <!-- 优先级 chip -->
                                                                        <Border x:Name="ChipPriorityBorder"
                                                                                Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipPriority_Click">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets"
                                                                                           Foreground="{Binding PriorityBrush}" FontSize="11"
                                                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                                <TextBlock Text="{Binding PriorityLabel}" Foreground="{StaticResource TextBrush2}" FontSize="11.5"
                                                                                           VerticalAlignment="Center"/>
                                                                                <Button Style="{StaticResource ChipCloseButton}"
                                                                                        Click="ChipPriorityRemove_Click"
                                                                                        Margin="6,0,0,0"
                                                                                        Visibility="{Binding IsMouseOver, ElementName=ChipPriorityBorder, Converter={StaticResource BoolToVisibility}}"/>
                                                                            </StackPanel>
                                                                            <Border.Style>
                                                                                <Style TargetType="Border" BasedOn="{StaticResource ClickablePill}">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding PriorityKey}" Value="none">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                        </Border>

                                                                        <!-- 标签 chip -->
                                                                        <Border x:Name="ChipCategoryBorder"
                                                                                Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipCategory_Click">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Ellipse Width="7" Height="7" Fill="{Binding CategoryBrush}"
                                                                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                                                <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource TextBrush2}" FontSize="11.5"
                                                                                           VerticalAlignment="Center"/>
                                                                                <Button Style="{StaticResource ChipCloseButton}"
                                                                                        Click="ChipCategoryRemove_Click"
                                                                                        Margin="6,0,0,0"
                                                                                        Visibility="{Binding IsMouseOver, ElementName=ChipCategoryBorder, Converter={StaticResource BoolToVisibility}}"/>
                                                                            </StackPanel>
                                                                            <Border.Style>
                                                                                <Style TargetType="Border" BasedOn="{StaticResource ClickablePill}">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding CategoryName}" Value="{x:Null}">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                        </Border>

                                                                        <!-- ====== 占位符：所有 "+" 按钮排在已有 chip 后面 ====== -->
                                                                        <Border Background="Transparent"
                                                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                                                Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipDate_Click">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border" BasedOn="{StaticResource ClickablePill}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding DueLabel}" Value="">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="+ 日期"
                                                                                       Foreground="{StaticResource MutedBrush}"
                                                                                       FontSize="11.5"/>
                                                                        </Border>

                                                                        <Border Background="Transparent"
                                                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                                                Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipPriority_Click">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border" BasedOn="{StaticResource ClickablePill}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding PriorityKey}" Value="none">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="+ 优先级"
                                                                                       Foreground="{StaticResource MutedBrush}"
                                                                                       FontSize="11.5"/>
                                                                        </Border>

                                                                        <Border Background="Transparent"
                                                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                                                Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipCategory_Click">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border" BasedOn="{StaticResource ClickablePill}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding CategoryName}" Value="{x:Null}">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <TextBlock Text="+ 标签"
                                                                                       Foreground="{StaticResource MutedBrush}"
                                                                                       FontSize="11.5"/>
                                                                        </Border>
                                                                    </WrapPanel>

                                                                </Grid>

                                                                <Border Background="{StaticResource PanelBrush}"
                                                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="9,7"
                                                                        Margin="0,0,0,9">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Notes}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding Notes}"
                                                                               TextWrapping="Wrap"
                                                                               Foreground="{StaticResource TextBrush2}"
                                                                               FontSize="12"
                                                                               LineHeight="18"/>
                                                                </Border>

                                                                <Grid Margin="0,2,0,8" Height="28">
                                                                    <Button HorizontalAlignment="Stretch"
                                                                            HorizontalContentAlignment="Left"
                                                                            BorderThickness="0"
                                                                            Background="Transparent"
                                                                            Padding="4,5"
                                                                            FontFamily="{StaticResource FontUI}"
                                                                            FontSize="12"
                                                                            Foreground="{StaticResource MutedBrush}"
                                                                            Cursor="Hand"
                                                                            Content="+ 添加子任务"
                                                                            Click="AddSubtaskButton_Click">
                                                                        <Button.Template>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="Bd"
                                                                                        Background="{TemplateBinding Background}"
                                                                                        CornerRadius="6"
                                                                                        Padding="{TemplateBinding Padding}">
                                                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                                      VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Button.Template>
                                                                        <Button.Style>
                                                                            <Style TargetType="Button">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsAddingSubtask}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Border Padding="5,2" CornerRadius="8">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
                                                                                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsAddingSubtask}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                                        <Setter Property="Effect" Value="{StaticResource ShadowFocus}"/>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="14"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <Ellipse Width="11" Height="11"
                                                                                     Stroke="{StaticResource Ink4Brush}"
                                                                                     StrokeThickness="1.4"
                                                                                     Fill="Transparent"
                                                                                     VerticalAlignment="Center"
                                                                                     Margin="3,0,0,0"/>
                                                                            <TextBox Grid.Column="1"
                                                                                     Margin="8,0,0,0"
                                                                                     Padding="0,2"
                                                                                     BorderThickness="0"
                                                                                     Background="Transparent"
                                                                                     FontSize="13"
                                                                                     VerticalAlignment="Center"
                                                                                     Text="{Binding DraftSubtaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                                                                     KeyDown="NewSubtaskBox_KeyDown"
                                                                                     LostFocus="NewSubtaskBox_LostFocus"
                                                                                     IsVisibleChanged="NewSubtaskBox_IsVisibleChanged"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </Grid>

                                                                <ItemsControl ItemsSource="{Binding Subtasks}"
                                                                              FocusVisualStyle="{x:Null}"
                                                                              Focusable="False">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                                                                            <Border x:Name="SubRow"
                                                                                    FocusVisualStyle="{x:Null}"
                                                                                    Tag="{Binding}"
                                                                                    PreviewMouseLeftButtonDown="SubtaskRow_PreviewMouseLeftButtonDown"
                                                                                    PreviewMouseMove="SubtaskRow_PreviewMouseMove"
                                                                                    MouseLeftButtonUp="SubtaskRow_MouseLeftButtonUp">
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border">
                                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                                                        <Setter Property="BorderThickness" Value="1"/>
                                                                                        <Setter Property="CornerRadius" Value="6"/>
                                                                                        <Setter Property="Padding" Value="4,3"/>
                                                                                        <Style.Triggers>
                                                                                            <!-- 普通 hover：半透明黑叠加 -->
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter Property="Background" Value="#14000000"/>
                                                                                            </Trigger>
                                                                                            <!-- 编辑态：仿添加子任务的白卡 -->
                                                                                            <DataTrigger Binding="{Binding IsInlineEditing}" Value="True">
                                                                                                <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
                                                                                                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                                                                                <Setter Property="CornerRadius" Value="8"/>
                                                                                                <Setter Property="Padding" Value="5,2"/>
                                                                                            </DataTrigger>
                                                                                            <!-- 编辑态聚焦：主色描边 + 焦点光晕 -->
                                                                                            <MultiDataTrigger>
                                                                                                <MultiDataTrigger.Conditions>
                                                                                                    <Condition Binding="{Binding IsInlineEditing}" Value="True"/>
                                                                                                    <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="True"/>
                                                                                                </MultiDataTrigger.Conditions>
                                                                                                <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
                                                                                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                                                <Setter Property="CornerRadius" Value="8"/>
                                                                                                <Setter Property="Padding" Value="5,2"/>
                                                                                                <Setter Property="Effect" Value="{StaticResource ShadowFocus}"/>
                                                                                            </MultiDataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="12"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="22"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <CheckBox Style="{StaticResource RoundCheckBox}"
                                                                                              Width="12" Height="12"
                                                                                              IsChecked="{Binding Completed, Mode=OneWay}"
                                                                                              Tag="{Binding PriorityKey}"
                                                                                              Click="CompleteCheckbox_Click"
                                                                                              VerticalAlignment="Center"/>

                                                                                    <!-- 标题：非编辑态显示 TextBlock，编辑态显示 TextBox -->
                                                                                    <Grid Grid.Column="1" Margin="8,0,8,0">
                                                                                        <TextBlock Text="{Binding Title}"
                                                                                                   VerticalAlignment="Center"
                                                                                                   Cursor="IBeam">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource TaskTitleText}">
                                                                                                    <Setter Property="FontSize" Value="13"/>
                                                                                                    <Setter Property="LineHeight" Value="18"/>
                                                                                                    <Setter Property="MaxHeight" Value="54"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding Completed}" Value="True">
                                                                                                            <Setter Property="TextDecorations" Value="{StaticResource StrikethroughCentered}"/>
                                                                                                            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                                                                        </DataTrigger>
                                                                                                        <DataTrigger Binding="{Binding IsInlineEditing}" Value="True">
                                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                        <TextBox Text="{Binding EditingTitle, UpdateSourceTrigger=PropertyChanged}"
                                                                                                 FontSize="13"
                                                                                                 Padding="2,0"
                                                                                                 BorderThickness="0"
                                                                                                 Background="Transparent"
                                                                                                 VerticalContentAlignment="Center"
                                                                                                 KeyDown="SubtaskEdit_KeyDown"
                                                                                                 LostFocus="SubtaskEdit_LostFocus"
                                                                                                 IsVisibleChanged="SubtaskEdit_IsVisibleChanged">
                                                                                            <TextBox.Style>
                                                                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsInlineEditing}" Value="True">
                                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBox.Style>
                                                                                        </TextBox>
                                                                                    </Grid>

                                                                                    <!-- 删除按钮：固定 22px 宽位，hover 才浮出，不引起重排；编辑态隐藏 -->
                                                                                    <Button Grid.Column="2"
                                                                                            Width="20" Height="20" FontSize="10"
                                                                                            Content="&#xE74D;"
                                                                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                            CommandParameter="{Binding}">
                                                                                        <Button.Style>
                                                                                            <Style TargetType="Button" BasedOn="{StaticResource GlyphButton}">
                                                                                                <Setter Property="Opacity" Value="0"/>
                                                                                                <Setter Property="IsHitTestVisible" Value="False"/>
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=SubRow}" Value="True">
                                                                                                        <Setter Property="Opacity" Value="1"/>
                                                                                                        <Setter Property="IsHitTestVisible" Value="True"/>
                                                                                                    </DataTrigger>
                                                                                                    <DataTrigger Binding="{Binding IsInlineEditing}" Value="True">
                                                                                                        <Setter Property="Opacity" Value="0"/>
                                                                                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </Button.Style>
                                                                                    </Button>
                                                                                </Grid>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                        </ctl:AnimatedExpander>
                                                    </StackPanel>
                                                    <DataTemplate.Triggers>
                                                        <!-- 展开高度由 AnimatedExpander 处理，这里只做内容淡入和轻微位移。 -->
                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="ExpandPane" Storyboard.TargetProperty="Opacity"
                                                                                         To="1" Duration="0:0:0.22" BeginTime="0:0:0.05">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation Storyboard.TargetName="ExpandContentShift" Storyboard.TargetProperty="Y"
                                                                                         To="0" Duration="0:0:0.32">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="ExpandPane" Storyboard.TargetProperty="Opacity"
                                                                                         To="0" Duration="0:0:0.10">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseIn"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                        <DoubleAnimation Storyboard.TargetName="ExpandContentShift" Storyboard.TargetProperty="Y"
                                                                                         To="-4" Duration="0:0:0.14">
                                                                            <DoubleAnimation.EasingFunction>
                                                                                <CubicEase EasingMode="EaseIn"/>
                                                                            </DoubleAnimation.EasingFunction>
                                                                        </DoubleAnimation>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,80,0,40">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasTaskGroups}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- 装饰性图标徽章：浅橘圆底 + 主色描线打勾 -->
                        <Border Width="60" Height="60"
                                CornerRadius="30"
                                Background="{StaticResource AccentSoftBrush}"
                                HorizontalAlignment="Center">
                            <TextBlock Text="&#xE73E;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="26"
                                       Foreground="{StaticResource AccentInkBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="{Binding EmptyTitle}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Ink2Brush}"
                                   Margin="0,18,0,0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding EmptySubtitle}"
                                   Foreground="{StaticResource Ink3Brush}"
                                   FontSize="12"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="3"
                    Background="{StaticResource Glass2Brush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,18,18"
                    Padding="10,6">
                <Grid>
                    <!-- 单行自适应：按数量降序排列；放不下的不渲染，但 OverflowHidePanel 会留出 30px 给右侧的 "…" -->
                    <ItemsControl x:Name="CategoryFilterStrip"
                                  ItemsSource="{Binding CategoryFilters}"
                                  FocusVisualStyle="{x:Null}"
                                  Focusable="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ctl:OverflowHidePanel OverflowIndicatorWidth="34"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CategoryFilterViewModel}">
                                <Button Style="{StaticResource CategoryPillButton}"
                                        Margin="0,2,4,2"
                                        Command="{Binding DataContext.SelectCategoryFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{Binding Brush}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11.5"/>
                                        <TextBlock Text="{Binding Count, StringFormat=' {0}'}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="10.5"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 溢出指示器：贴右边、低存在感的三点；hover 时变 Accent 色，不出现明显的胶囊框 -->
                    <Button x:Name="CategoryMoreButton"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="32"
                            Height="22"
                            Visibility="Collapsed"
                            Click="CategoryMoreButton_Click"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            Focusable="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <Ellipse x:Name="D1" Width="3" Height="3" Fill="{StaticResource Ink3Brush}" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                        <Ellipse x:Name="D2" Width="3" Height="3" Fill="{StaticResource Ink3Brush}" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                        <Ellipse x:Name="D3" Width="3" Height="3" Fill="{StaticResource Ink3Brush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#10000000"/>
                                        <Setter TargetName="D1" Property="Fill" Value="{StaticResource AccentInkBrush}"/>
                                        <Setter TargetName="D2" Property="Fill" Value="{StaticResource AccentInkBrush}"/>
                                        <Setter TargetName="D3" Property="Fill" Value="{StaticResource AccentInkBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- 溢出分类下拉：列出当前隐藏的分类 -->
            <Popup x:Name="CategoryOverflowPopup"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   StaysOpen="False"
                   Placement="Top"
                   PlacementTarget="{Binding ElementName=CategoryMoreButton}">
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="6"
                        MinWidth="160">
                    <ItemsControl x:Name="CategoryOverflowList"
                                  FocusVisualStyle="{x:Null}"
                                  Focusable="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CategoryFilterViewModel}">
                                <Button Style="{StaticResource QuickFlyoutButton}"
                                        Click="CategoryOverflowItem_Click"
                                        Tag="{Binding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding Brush}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Count}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Popup>

            <Popup x:Name="QuickFlyout"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   StaysOpen="False"
                   Placement="Bottom">
                <!-- 透明 popup 里不挂 DropShadowEffect：渲染面是矩形，shadow 会被 clip 出方框 -->
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="11"
                        Padding="6">
                    <ContentControl x:Name="QuickFlyoutContent"/>
                </Border>
            </Popup>
        </Grid>
        </AdornerDecorator>
    </Border>
</Window>
