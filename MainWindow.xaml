<Window x:Class="TodoFloat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TodoFloat.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="TodoFloat"
        Width="{StaticResource WindowWidth}" Height="{StaticResource WindowHeight}"
        MinWidth="320" MinHeight="380"
        Background="{DynamicResource GlassBrush}"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResize"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome ResizeBorderThickness="6"
                            CaptionHeight="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Style="{StaticResource AppWindowShell}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="DragBar"
                  Grid.Row="0"
                  Background="Transparent"
                  Cursor="SizeAll">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                    <Ellipse Style="{StaticResource TrafficDot}" Fill="#E8664E" Margin="0,0,6,0"/>
                    <Ellipse Style="{StaticResource TrafficDot}" Fill="#E5B84B" Margin="0,0,6,0"/>
                    <Ellipse Style="{StaticResource TrafficDot}" Fill="#62C46E"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="&#xE718;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="11"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock Text="Loop · 悬浮"
                               Foreground="{StaticResource TextBrush2}"
                               FontSize="12.5"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Button Style="{StaticResource GlyphButton}"
                            Content="&#xE721;"
                            ToolTip="搜索"
                            Click="BtnSearch_Click"/>
                    <Button x:Name="BtnPin"
                            Style="{StaticResource GlyphButton}"
                            Content="&#xE718;"
                            ToolTip="置顶"
                            Click="BtnPin_Click"/>
                    <Button Style="{StaticResource GlyphButton}"
                            Content="&#xE712;"
                            ToolTip="更多"/>
                    <Button x:Name="BtnClose"
                            Style="{StaticResource GlyphButton}"
                            Content="&#xE8BB;"
                            ToolTip="关闭"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="16,14,16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SegmentedShell}"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Style="{StaticResource SegmentedToggleButton}"
                                          IsChecked="{Binding IsTodayView, Mode=TwoWay}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="待办" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding TodayCount, StringFormat=' {0}'}"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="10.5"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton Style="{StaticResource SegmentedToggleButton}"
                                          IsChecked="{Binding IsUpcomingView, Mode=TwoWay}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="规划" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding UpcomingCount, StringFormat=' {0}'}"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="10.5"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton Style="{StaticResource SegmentedToggleButton}"
                                          IsChecked="{Binding IsInboxView, Mode=TwoWay}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="全部" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding InboxCount, StringFormat=' {0}'}"
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="10.5"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource GlyphButton}"
                                Content="&#xE721;"
                                ToolTip="搜索"
                                Click="BtnSearch_Click"/>
                        <Button Style="{StaticResource GlyphButton}"
                                Content="&#xEA8F;"
                                ToolTip="通知"/>
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource GlyphButton}"
                                Content="&#xE713;"
                                ToolTip="设置"
                                Click="BtnSettings_Click">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="显示已完成"
                                              IsCheckable="True"
                                              IsChecked="{Binding ShowCompleted}"
                                              Command="{Binding ToggleShowCompletedCommand}"/>
                                    <MenuItem Header="自动隐藏"
                                              IsCheckable="True"
                                              IsChecked="{Binding AutoHideEnabled}"
                                              Command="{Binding ToggleAutoHideCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="分类管理…" Click="MenuCategories_Click"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,12,0,0" HorizontalAlignment="Right">
                    <TextBlock HorizontalAlignment="Right"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11.5">
                        <Run Text="{Binding CompletedCount}"/>
                        <Run Text="/"/>
                        <Run Text="{Binding TotalCount}"/>
                        <Run Text=" 已完成"/>
                    </TextBlock>
                    <ProgressBar Style="{StaticResource WindowProgress}"
                                 Value="{Binding CompletionPercent, Mode=OneWay}"
                                 Margin="0,5,0,0"/>
                </StackPanel>

                <Border x:Name="NewTaskRow"
                        Style="{StaticResource QuickAddShell}"
                        Margin="0,14,0,0"
                        MouseLeftButtonDown="NewTaskRow_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="QuickAddButton"
                                Width="28"
                                Height="28"
                                VerticalAlignment="Center"
                                Click="QuickAddButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid>
                                        <Ellipse x:Name="Circle"
                                                 Width="22"
                                                 Height="22"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Stroke="{StaticResource MutedBrush}"
                                                 StrokeThickness="0.9"
                                                 StrokeDashArray="2.4 2.0"
                                                 StrokeDashCap="Round"
                                                 Fill="Transparent"/>
                                        <Path Data="M 0,5 L 10,5 M 5,0 L 5,10"
                                              Stroke="{StaticResource MutedBrush}"
                                              StrokeThickness="1.3"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Width="10" Height="10"
                                              Stretch="None"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </Grid>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Grid Grid.Column="1" Margin="8,0,8,0">
                            <TextBox x:Name="NewTaskBox"
                                     Text="{Binding QuickInput, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="NewTaskBox_KeyDown"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Text="添加任务... 今天 14:30 #工作 !!"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding QuickInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource GlyphButton}"
                                    Width="22" Height="22"
                                    Content="&#xE787;"
                                    Margin="0,0,2,0"
                                    ToolTip="日期"
                                    Click="QuickDueButton_Click"/>
                            <Button Style="{StaticResource GlyphButton}"
                                    Width="22" Height="22"
                                    Content="&#xE823;"
                                    Margin="0,0,2,0"
                                    ToolTip="时间"
                                    Click="QuickTimeButton_Click"/>
                            <Button Style="{StaticResource GlyphButton}"
                                    Width="22" Height="22"
                                    Content="&#xE7C1;"
                                    Margin="0,0,2,0"
                                    ToolTip="优先级"
                                    Click="QuickPriorityButton_Click"/>
                            <Button Style="{StaticResource GlyphButton}"
                                    Width="22" Height="22"
                                    Content="&#xE8EC;"
                                    Margin="0,0,4,0"
                                    Click="QuickTagButton_Click"/>
                            <Border Background="{StaticResource PanelBrush2}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="5,1">
                                <TextBlock Text="Ctrl+N" FontSize="10.5" Foreground="{StaticResource MutedBrush}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <WrapPanel Margin="0,8,0,0">
                    <WrapPanel.Style>
                        <Style TargetType="WrapPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasQuickChips}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>

                    <Border Margin="0,0,6,4">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Pill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QuickChipDueLabel}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding QuickChipDueLabel}"
                                       Foreground="{StaticResource TextBrush2}"
                                       FontSize="11.5"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource ChipCloseButton}"
                                    Command="{Binding ClearDueChipCmdCommand}"
                                    Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,6,4">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Pill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QuickChipPriorityLabel}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C1;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{Binding QuickChipPriorityBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding QuickChipPriorityLabel}"
                                       Foreground="{StaticResource TextBrush2}"
                                       FontSize="11.5"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource ChipCloseButton}"
                                    Command="{Binding ClearPriorityChipCmdCommand}"
                                    Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,6,4">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Pill}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QuickChipCategoryName}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     Fill="{Binding QuickChipCategoryBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding QuickChipCategoryName}"
                                       Foreground="{StaticResource TextBrush2}"
                                       FontSize="11.5"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource ChipCloseButton}"
                                    Command="{Binding ClearCategoryChipCmdCommand}"
                                    Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Grid x:Name="SearchPanel"
                      Visibility="Collapsed"
                      Background="Transparent"
                      Margin="0,8,0,0">
                    <Border Background="{StaticResource PanelBrush2}"
                            CornerRadius="8"
                            Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                                     KeyDown="SearchBox_KeyDown"
                                     Margin="8,0,8,0"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource GlyphButton}"
                                    Width="20"
                                    Height="20"
                                    FontSize="10"
                                    Content="&#xE8BB;"
                                    Click="ClearSearch_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,10,12,8">
                <Grid>
                    <ItemsControl ItemsSource="{Binding TaskGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TaskGroupViewModel}">
                                <StackPanel Margin="0,0,0,14">
                                    <Grid Margin="6,2,6,4"
                                          Visibility="{Binding ShowHeader, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="11.5"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush2}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAccent}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentInkBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Subtitle, StringFormat=' · {0}'}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="11.5"
                                                   Margin="8,0,0,0"/>
                                    </Grid>

                                    <Border Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="12"
                                            ClipToBounds="False">
                                        <ItemsControl ItemsSource="{Binding Tasks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                                                    <StackPanel Margin="0,0,0,2">
                                                        <Border Tag="{Binding}"
                                                                CornerRadius="{Binding RowCornerRadius}"
                                                                MouseLeftButtonUp="TaskRow_LeftClick"
                                                                MouseRightButtonUp="TaskRow_RightClick">
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource TaskRow}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                                            <Setter Property="BorderThickness" Value="0"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="22"/>
                                                                    <ColumnDefinition Width="14"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Border Grid.ColumnSpan="4"
                                                                        Width="2.5"
                                                                        HorizontalAlignment="Left"
                                                                        Margin="-6,2,0,0"
                                                                        Background="{StaticResource AccentBrush}"
                                                                        CornerRadius="0,3,3,0"
                                                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}"/>

                                                                <UniformGrid Rows="3"
                                                                             Columns="2"
                                                                             Width="8"
                                                                             Height="16"
                                                                             HorizontalAlignment="Left"
                                                                             VerticalAlignment="Center"
                                                                             Margin="0,0,0,0">
                                                                    <UniformGrid.Style>
                                                                        <Style TargetType="UniformGrid">
                                                                            <Setter Property="Opacity" Value="0"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                                    <Setter Property="Opacity" Value="0.55"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </UniformGrid.Style>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                    <Ellipse Width="2" Height="2" Fill="{StaticResource FaintBrush}"/>
                                                                </UniformGrid>

                                                                <CheckBox Grid.Column="1"
                                                                          Style="{StaticResource RoundCheckBox}"
                                                                          Width="14" Height="14"
                                                                          Margin="0,3,0,0"
                                                                          IsChecked="{Binding Completed, Mode=OneWay}"
                                                                          Tag="{Binding PriorityKey}"
                                                                          Click="CompleteCheckbox_Click"
                                                                          VerticalAlignment="Top"/>

                                                                <StackPanel Grid.Column="2" Margin="10,0,8,0">
                                                                    <TextBlock Text="{Binding Title}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource TaskTitleText}">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Completed}" Value="True">
                                                                                        <Setter Property="TextDecorations" Value="{StaticResource StrikethroughCentered}"/>
                                                                                        <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>

                                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                                                            <StackPanel.Style>
                                                                                <Style TargetType="StackPanel">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding CategoryName}" Value="{x:Null}">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </StackPanel.Style>
                                                                            <Ellipse Width="7" Height="7"
                                                                                     Fill="{Binding CategoryBrush}"
                                                                                     VerticalAlignment="Center"
                                                                                     Margin="0,0,4,0"/>
                                                                            <TextBlock Text="{Binding CategoryName}" Style="{StaticResource MetaText}"/>
                                                                        </StackPanel>

                                                                        <TextBlock Text="{Binding DueLabel}" Margin="0,0,8,0">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource MetaText}">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding DueLabel}" Value="">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>

                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Margin="0,0,8,0"
                                                                                    VerticalAlignment="Center">
                                                                            <StackPanel.Style>
                                                                                <Style TargetType="StackPanel">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasSubtasks}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </StackPanel.Style>
                                                                            <ProgressBar Style="{StaticResource WindowProgress}"
                                                                                         Width="44"
                                                                                         Height="4"
                                                                                         Value="{Binding SubtaskProgress, Mode=OneWay}"
                                                                                         VerticalAlignment="Center"
                                                                                         Margin="0,0,6,0"/>
                                                                            <TextBlock Text="{Binding SubtaskSummary}"
                                                                                       Style="{StaticResource MetaText}"
                                                                                       VerticalAlignment="Center"/>
                                                                        </StackPanel>

                                                                    </StackPanel>
                                                                </StackPanel>

                                                                <TextBlock Grid.Column="3"
                                                                           Text="&#xE7C1;"
                                                                           FontFamily="Segoe MDL2 Assets"
                                                                           Foreground="{Binding PriorityBrush}"
                                                                           FontSize="12"
                                                                           VerticalAlignment="Top">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding PriorityKey}" Value="none">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                        </Border>

                                                        <Border Background="{StaticResource AccentSoftBrush}"
                                                                BorderBrush="{StaticResource Line2Brush}"
                                                                BorderThickness="0,1,0,0"
                                                                CornerRadius="{Binding DetailCornerRadius}"
                                                                Padding="0"
                                                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                                            <Grid>
                                                                <StackPanel Margin="46,7,14,12">
                                                                <Grid Margin="0,0,0,8">
                                                                    <WrapPanel>
                                                                        <Border Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipDate_Click">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                                                                           Foreground="{StaticResource MutedBrush}" FontSize="11"
                                                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                                <TextBlock Text="{Binding DueLabel}" Foreground="{StaticResource TextBrush2}" FontSize="11.5"/>
                                                                            </StackPanel>
                                                                            <Border.Style>
                                                                                <Style TargetType="Border" BasedOn="{StaticResource ClickablePill}">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding DueLabel}" Value="">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                        </Border>

                                                                        <Border Style="{StaticResource ClickablePill}"
                                                                                Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipPriority_Click">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets"
                                                                                           Foreground="{Binding PriorityBrush}" FontSize="11"
                                                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                                <TextBlock Text="{Binding PriorityLabel}" Foreground="{StaticResource TextBrush2}" FontSize="11.5"/>
                                                                            </StackPanel>
                                                                        </Border>

                                                                        <Border Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipCategory_Click">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Ellipse Width="7" Height="7" Fill="{Binding CategoryBrush}"
                                                                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                                                <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource TextBrush2}" FontSize="11.5"/>
                                                                            </StackPanel>
                                                                            <Border.Style>
                                                                                <Style TargetType="Border" BasedOn="{StaticResource ClickablePill}">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding CategoryName}" Value="{x:Null}">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                        </Border>

                                                                        <Border Style="{StaticResource ClickablePill}"
                                                                                Background="Transparent"
                                                                                BorderBrush="{StaticResource BorderBrushSoft}"
                                                                                Margin="0,0,6,6"
                                                                                MouseLeftButtonUp="ChipCategory_Click">
                                                                            <TextBlock Text="+ 标签"
                                                                                       Foreground="{StaticResource MutedBrush}"
                                                                                       FontSize="11.5"/>
                                                                        </Border>
                                                                    </WrapPanel>

                                                                </Grid>

                                                                <Border Background="{StaticResource PanelBrush}"
                                                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="9,7"
                                                                        Margin="0,0,0,9">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Notes}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Notes}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="{Binding Notes}"
                                                                               TextWrapping="Wrap"
                                                                               Foreground="{StaticResource TextBrush2}"
                                                                               FontSize="12"
                                                                               LineHeight="18"/>
                                                                </Border>

                                                                <ItemsControl ItemsSource="{Binding Subtasks}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                                                                            <Border CornerRadius="6"
                                                                                    Padding="4,3"
                                                                                    MouseRightButtonUp="TaskRow_RightClick"
                                                                                    Tag="{Binding}">
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border">
                                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                                        <Style.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                                                            </Trigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="12"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <CheckBox Style="{StaticResource RoundCheckBox}"
                                                                                              Width="12" Height="12"
                                                                                              IsChecked="{Binding Completed, Mode=OneWay}"
                                                                                              Tag="{Binding PriorityKey}"
                                                                                              Click="CompleteCheckbox_Click"
                                                                                              VerticalAlignment="Center"/>
                                                                                    <TextBlock Grid.Column="1"
                                                                                               Text="{Binding Title}"
                                                                                               Margin="8,0,8,0"
                                                                                               VerticalAlignment="Center">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource TaskTitleText}">
                                                                                                <Setter Property="FontSize" Value="12"/>
                                                                                                <Setter Property="LineHeight" Value="16"/>
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding Completed}" Value="True">
                                                                                                        <Setter Property="TextDecorations" Value="{StaticResource StrikethroughCentered}"/>
                                                                                                        <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                                                        <Button Style="{StaticResource GlyphButton}"
                                                                                                Width="20" Height="20" FontSize="10"
                                                                                                Content="&#xE70F;"
                                                                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                CommandParameter="{Binding}"/>
                                                                                        <Button Style="{StaticResource GlyphButton}"
                                                                                                Width="20" Height="20" FontSize="10"
                                                                                                Content="&#xE74D;"
                                                                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                                CommandParameter="{Binding}"/>
                                                                                    </StackPanel>
                                                                                </Grid>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>

                                                                <Grid Margin="0,2,0,0" Height="28">
                                                                    <Button HorizontalAlignment="Stretch"
                                                                            HorizontalContentAlignment="Left"
                                                                            BorderThickness="0"
                                                                            Background="Transparent"
                                                                            Padding="4,5"
                                                                            FontFamily="{StaticResource FontUI}"
                                                                            FontSize="12"
                                                                            Foreground="{StaticResource MutedBrush}"
                                                                            Cursor="Hand"
                                                                            Content="+ 添加子任务"
                                                                            Click="AddSubtaskButton_Click">
                                                                        <Button.Template>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="Bd"
                                                                                        Background="{TemplateBinding Background}"
                                                                                        CornerRadius="6"
                                                                                        Padding="{TemplateBinding Padding}">
                                                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                                      VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Button.Template>
                                                                        <Button.Style>
                                                                            <Style TargetType="Button">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsAddingSubtask}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>
                                                                    <Border Padding="5,2" CornerRadius="8">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
                                                                                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsAddingSubtask}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                                                        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                                                        <Setter Property="Effect" Value="{StaticResource ShadowFocus}"/>
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="14"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <Ellipse Width="11" Height="11"
                                                                                     Stroke="{StaticResource Ink4Brush}"
                                                                                     StrokeThickness="1.4"
                                                                                     Fill="Transparent"
                                                                                     VerticalAlignment="Center"
                                                                                     Margin="3,0,0,0"/>
                                                                            <TextBox Grid.Column="1"
                                                                                     Margin="8,0,0,0"
                                                                                     Padding="0,2"
                                                                                     BorderThickness="0"
                                                                                     Background="Transparent"
                                                                                     FontSize="12"
                                                                                     VerticalAlignment="Center"
                                                                                     Text="{Binding DraftSubtaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                                                                     KeyDown="NewSubtaskBox_KeyDown"
                                                                                     LostFocus="NewSubtaskBox_LostFocus"
                                                                                     IsVisibleChanged="NewSubtaskBox_IsVisibleChanged"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </Grid>

                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="18"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Margin="0,20,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasTaskGroups}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding EmptyTitle}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="从上方快速添加一项。"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="3"
                    Background="{StaticResource Glass2Brush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,18,18"
                    ClipToBounds="True"
                    Padding="12,8">
                <ScrollViewer x:Name="CategoryFilterScrollViewer"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              PanningMode="HorizontalOnly"
                              PreviewMouseWheel="CategoryFilterScrollViewer_PreviewMouseWheel">
                    <ItemsControl ItemsSource="{Binding CategoryFilters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CategoryFilterViewModel}">
                                <Button Style="{StaticResource CategoryPillButton}"
                                        Margin="0,0,4,0"
                                        Command="{Binding DataContext.SelectCategoryFilterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{Binding Brush}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11.5"/>
                                        <TextBlock Text="{Binding Count, StringFormat=' {0}'}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   FontSize="10.5"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Popup x:Name="QuickFlyout"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   StaysOpen="False"
                   Placement="Bottom">
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="11"
                        Padding="6"
                        Effect="{StaticResource ShadowSoft}">
                    <ContentControl x:Name="QuickFlyoutContent"/>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
