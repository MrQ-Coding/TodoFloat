<!--
  Loop Todo — Design Tokens for WPF / WinUI 3
  导入方式 (App.xaml):
    <Application.Resources>
      <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
          <ResourceDictionary Source="Colors.xaml"/>
          <ResourceDictionary Source="Styles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
      </ResourceDictionary>
    </Application.Resources>
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- ========== 尺寸 / 圆角 / 间距 ========== -->
  <sys:Double x:Key="WindowWidth">420</sys:Double>
  <sys:Double x:Key="WindowHeight">620</sys:Double>

  <CornerRadius x:Key="RadiusWindow">18</CornerRadius>
  <CornerRadius x:Key="RadiusLg">12</CornerRadius>
  <CornerRadius x:Key="RadiusMd">9</CornerRadius>
  <CornerRadius x:Key="RadiusSm">7</CornerRadius>
  <CornerRadius x:Key="RadiusPill">999</CornerRadius>

  <Thickness x:Key="SpaceXS">4</Thickness>
  <Thickness x:Key="SpaceS">8</Thickness>
  <Thickness x:Key="SpaceM">12</Thickness>
  <Thickness x:Key="SpaceL">16</Thickness>
  <Thickness x:Key="SpaceXL">22</Thickness>

  <!-- ========== 颜色 (Light) ==========
       原 oklch 已转换为最接近的 sRGB hex。
       暖橘 accent #E8915E ≈ oklch(0.68 0.16 35)
  -->
  <Color x:Key="C.Accent">#E8915E</Color>
  <Color x:Key="C.AccentSoft">#FBE7D6</Color>
  <Color x:Key="C.AccentInk">#A45A2C</Color>

  <Color x:Key="C.Bg">#F5EFE0</Color>
  <Color x:Key="C.Glass">#FFF5EFE0</Color>      <!-- opaque shell -->
  <Color x:Key="C.Glass2">#FFEBE3D2</Color>     <!-- opaque footer -->
  <Color x:Key="C.Panel">#FFFFFFFF</Color>
  <Color x:Key="C.Panel2">#FFEBE3D2</Color>

  <Color x:Key="C.Line">#FFE3E1DC</Color>
  <Color x:Key="C.Line2">#FFF0EEEB</Color>

  <!-- 行 hover 中性暖灰，与展开态 AccentSoft 形成区分 -->
  <Color x:Key="C.RowHover">#FFEBE6DE</Color>

  <Color x:Key="C.Ink">#2B2925</Color>
  <Color x:Key="C.Ink2">#5C5852</Color>
  <Color x:Key="C.Ink3">#857F77</Color>
  <Color x:Key="C.Ink4">#B5AEA4</Color>

  <Color x:Key="C.PriHigh">#D85A45</Color>
  <Color x:Key="C.PriMed">#E8915E</Color>
  <Color x:Key="C.PriLow">#A8A8B2</Color>

  <Color x:Key="C.ListWork">#E89060</Color>
  <Color x:Key="C.ListPersonal">#7B98E8</Color>
  <Color x:Key="C.ListDesign">#5FB58A</Color>
  <Color x:Key="C.ListHome">#C57BB8</Color>

  <!-- ========== Brushes ========== -->
  <SolidColorBrush x:Key="Accent" Color="{StaticResource C.Accent}"/>
  <SolidColorBrush x:Key="AccentSoft" Color="{StaticResource C.AccentSoft}"/>
  <SolidColorBrush x:Key="AccentInk" Color="{StaticResource C.AccentInk}"/>

  <SolidColorBrush x:Key="BgBrush" Color="{StaticResource C.Bg}"/>
  <SolidColorBrush x:Key="GlassBrush" Color="{StaticResource C.Glass}"/>
  <SolidColorBrush x:Key="Glass2Brush" Color="{StaticResource C.Glass2}"/>
  <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource C.Panel}"/>
  <SolidColorBrush x:Key="Panel2Brush" Color="{StaticResource C.Panel2}"/>

  <SolidColorBrush x:Key="LineBrush" Color="{StaticResource C.Line}"/>
  <SolidColorBrush x:Key="Line2Brush" Color="{StaticResource C.Line2}"/>
  <SolidColorBrush x:Key="RowHoverBrush" Color="{StaticResource C.RowHover}"/>

  <SolidColorBrush x:Key="InkBrush" Color="{StaticResource C.Ink}"/>
  <SolidColorBrush x:Key="Ink2Brush" Color="{StaticResource C.Ink2}"/>
  <SolidColorBrush x:Key="Ink3Brush" Color="{StaticResource C.Ink3}"/>
  <SolidColorBrush x:Key="Ink4Brush" Color="{StaticResource C.Ink4}"/>

  <SolidColorBrush x:Key="PriHighBrush" Color="{StaticResource C.PriHigh}"/>
  <SolidColorBrush x:Key="PriMedBrush" Color="{StaticResource C.PriMed}"/>
  <SolidColorBrush x:Key="PriLowBrush" Color="{StaticResource C.PriLow}"/>

  <!-- 头像渐变 -->
  <LinearGradientBrush x:Key="AvatarBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#F0A479" Offset="0"/>
    <GradientStop Color="#C26A3F" Offset="1"/>
  </LinearGradientBrush>

  <!-- ========== Typography ========== -->
  <FontFamily x:Key="FontUI">Inter, Segoe UI Variable, Segoe UI</FontFamily>
  <FontFamily x:Key="FontMono">Cascadia Mono, Consolas</FontFamily>

  <sys:Double x:Key="Fs.XS">10.5</sys:Double>
  <sys:Double x:Key="Fs.SM">11.5</sys:Double>
  <sys:Double x:Key="Fs.Body">13</sys:Double>
  <sys:Double x:Key="Fs.Title">14</sys:Double>
  <sys:Double x:Key="Fs.H2">17</sys:Double>
  <sys:Double x:Key="Fs.H1">22</sys:Double>

  <!-- ========== Shadows ==========
       窗口主阴影 — 在根 Border 上用 DropShadowEffect -->
  <DropShadowEffect x:Key="ShadowWindow"
                    BlurRadius="80"
                    ShadowDepth="20"
                    Opacity="0.35"
                    Color="#000000"
                    Direction="270"/>

  <DropShadowEffect x:Key="ShadowSoft"
                    BlurRadius="12"
                    ShadowDepth="2"
                    Opacity="0.08"
                    Color="#000000"
                    Direction="270"/>

  <DropShadowEffect x:Key="ShadowFocus"
                    BlurRadius="14"
                    ShadowDepth="0"
                    Opacity="0.32"
                    Color="#E8915E"/>
</ResourceDictionary>
