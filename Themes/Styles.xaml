<!--
  Loop Todo — 控件样式 (WPF)
  依赖 Colors.xaml
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ========== 窗口外壳 ========== -->
  <!--
    用法 (MainWindow.xaml):
    <Window WindowStyle="None"
            AllowsTransparency="True"
            Background="Transparent"
            ResizeMode="NoResize"
            Topmost="True"
            Width="{StaticResource WindowWidth}"
            Height="{StaticResource WindowHeight}">
      <Border Style="{StaticResource WindowShell}">
        ...
      </Border>
    </Window>
  -->
  <Style x:Key="WindowShell" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
    <Setter Property="CornerRadius" Value="{StaticResource RadiusWindow}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="BorderBrush" Value="#22000000"/>
    <Setter Property="Effect" Value="{StaticResource ShadowWindow}"/>
    <Setter Property="Margin" Value="40"/>
  </Style>

  <!-- ========== Titlebar ========== -->
  <Style x:Key="Titlebar" TargetType="Border">
    <Setter Property="Height" Value="38"/>
    <Setter Property="Padding" Value="14,0"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
    <!-- code-behind: MouseLeftButtonDown="OnTitlebarDrag" -> this.DragMove() -->
  </Style>

  <Style x:Key="TrafficDot" TargetType="Ellipse">
    <Setter Property="Width" Value="11"/>
    <Setter Property="Height" Value="11"/>
  </Style>

  <!-- ========== Quick add ========== -->
  <Style x:Key="QuickAddShell" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="11"/>
    <Setter Property="Padding" Value="10,7"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#FFFAF7F2"/>
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
      </Trigger>
      <Trigger Property="IsKeyboardFocusWithin" Value="True">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        <Setter Property="Effect" Value="{StaticResource ShadowFocus}"/>
      </Trigger>
      <!-- Code-behind sets Tag="active" while a quick-add flyout (date/time/priority/tag) is open,
           so the row keeps its active styling instead of going dim during selection. -->
      <Trigger Property="Tag" Value="active">
        <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
        <Setter Property="Effect" Value="{StaticResource ShadowFocus}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="QuickAddInput" TargetType="TextBox">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Padding" Value="2,0"/>
  </Style>

  <!-- ========== Segmented control (Today / Upcoming / Inbox) ========== -->
  <Style x:Key="SegmentedShell" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="9"/>
    <Setter Property="Padding" Value="2"/>
  </Style>

  <Style x:Key="SegmentedButton" TargetType="ToggleButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource Ink3Brush}"/>
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="Transparent"
                  BorderThickness="1"
                  CornerRadius="7"
                  Padding="{TemplateBinding Padding}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,0,0,1"/>
          </Border>
          <ControlTemplate.Triggers>
            <!-- 未选中态 hover：仿输入框样式 — 暖白底 + 主色描边 -->
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True"/>
                <Condition Property="IsChecked" Value="False"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="Bd" Property="Background" Value="#FFFAF7F2"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
              <Setter Property="Foreground" Value="{StaticResource AccentInk}"/>
            </MultiTrigger>
            <!-- 选中态：浅橘底 + 主色描边 + 深橘字（柔和有质感） -->
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoft}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
              <Setter Property="Foreground" Value="{StaticResource AccentInk}"/>
            </Trigger>
            <!-- 选中态再 hover：底色稍微深一档 -->
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True"/>
                <Condition Property="IsChecked" Value="True"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="Bd" Property="Background" Value="#FFF3CFB3"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
              <Setter Property="Foreground" Value="{StaticResource AccentInk}"/>
            </MultiTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ========== 任务复选框 ==========
       绑定: IsChecked="{Binding IsDone}"
              Tag="{Binding Priority}"  (high/med/low) -->
  <Style x:Key="TaskCheck" TargetType="CheckBox">
    <Setter Property="Width" Value="20"/>
    <Setter Property="Height" Value="20"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <Grid>
            <Ellipse x:Name="Ring"
                     Stroke="{StaticResource Ink4Brush}"
                     StrokeThickness="1.6"
                     Fill="Transparent"/>
            <Path x:Name="Tick"
                  Data="M 0,2 L 2,4 L 5,0"
                  Stretch="None"
                  Stroke="White"
                  StrokeThickness="1.4"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Visibility="Collapsed"/>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="Tag" Value="high">
              <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource PriHighBrush}"/>
            </Trigger>
            <Trigger Property="Tag" Value="med">
              <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource PriMedBrush}"/>
            </Trigger>
            <Trigger Property="Tag" Value="low">
              <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource PriLowBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Ring" Property="Fill" Value="{StaticResource Accent}"/>
              <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource Accent}"/>
              <Setter TargetName="Tick" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Ring" Property="Stroke" Value="{StaticResource Accent}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ========== 任务行容器 ========== -->
  <Style x:Key="TaskRow" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource Line2Brush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,9,10,9"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- ========== 文本样式 ========== -->
  <Style x:Key="TaskTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
  </Style>

  <Style x:Key="TaskMeta" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Foreground" Value="{StaticResource Ink3Brush}"/>
  </Style>

  <Style x:Key="HeadGreet" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource Ink3Brush}"/>
    <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
  </Style>

  <Style x:Key="HeadTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="22"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
  </Style>

  <Style x:Key="GroupHeader" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource FontUI}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource Ink2Brush}"/>
    <!-- letter-spacing 0.06em -> 在 WPF: TextOptions/CharacterSpacing -->
  </Style>

  <!-- ========== Pill / Tag chip ========== -->
  <Style x:Key="Pill" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="7"/>
    <Setter Property="Padding" Value="8,3"/>
  </Style>

  <Style x:Key="ClickablePill" TargetType="Border" BasedOn="{StaticResource Pill}">
    <Setter Property="Cursor" Value="Hand"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="TagChip" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource Panel2Brush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="5,0"/>
  </Style>

  <!-- ========== 进度条 ========== -->
  <Style x:Key="ThinProgress" TargetType="ProgressBar">
    <Setter Property="Height" Value="8"/>
    <Setter Property="Width" Value="130"/>
    <Setter Property="Minimum" Value="0"/>
    <Setter Property="Maximum" Value="100"/>
    <Setter Property="Background" Value="#FFEAE4DA"/>
    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Border CornerRadius="3"
                  Background="{TemplateBinding Background}"
                  ClipToBounds="True">
            <Grid HorizontalAlignment="Stretch">
              <Border x:Name="PART_Track" Background="Transparent"/>
              <Border x:Name="PART_Indicator"
                      HorizontalAlignment="Left"
                      Background="{TemplateBinding Foreground}"
                      CornerRadius="3"/>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ========== 列表点 (颜色绑定 List.Color) ========== -->
  <Style x:Key="ListDot" TargetType="Ellipse">
    <Setter Property="Width" Value="7"/>
    <Setter Property="Height" Value="7"/>
  </Style>

  <!-- ========== 头像 ========== -->
  <Style x:Key="Avatar" TargetType="Border">
    <Setter Property="Width" Value="22"/>
    <Setter Property="Height" Value="22"/>
    <Setter Property="CornerRadius" Value="11"/>
    <Setter Property="Background" Value="{StaticResource AvatarBrush}"/>
  </Style>

  <!-- ========== 图标按钮 ========== -->
  <Style x:Key="IconButton" TargetType="Button">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Width" Value="24"/>
    <Setter Property="Height" Value="24"/>
    <Setter Property="Foreground" Value="{StaticResource Ink3Brush}"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoft}"/>
              <Setter Property="Foreground" Value="{StaticResource AccentInk}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
