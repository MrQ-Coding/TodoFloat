<Window x:Class="TodoFloat.Views.DesktopPetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nibble · TodoFloat 桌面宠物"
        Width="620" Height="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Grayscale">

    <Window.Resources>
        <Color x:Key="Bg1">#FBF2E1</Color>
        <Color x:Key="Cream">#FFF6E6</Color>
        <Color x:Key="Ink">#3B2A1C</Color>
        <Color x:Key="Ink2">#6E523B</Color>
        <Color x:Key="Ink3">#A38062</Color>
        <Color x:Key="Line">#E6CFA8</Color>
        <Color x:Key="Outline">#4A2E18</Color>
        <Color x:Key="Pet1">#F4A574</Color>
        <Color x:Key="Pet2">#E58748</Color>
        <Color x:Key="Pet3">#C66526</Color>
        <Color x:Key="PetCheek">#F08770</Color>
        <Color x:Key="PetBelly">#FFE9CC</Color>
        <Color x:Key="Accent">#D9622A</Color>

        <SolidColorBrush x:Key="InkBrush" Color="{StaticResource Ink}"/>
        <SolidColorBrush x:Key="Ink2Brush" Color="{StaticResource Ink2}"/>
        <SolidColorBrush x:Key="Ink3Brush" Color="{StaticResource Ink3}"/>
        <SolidColorBrush x:Key="OutlineBrush" Color="{StaticResource Outline}"/>
        <SolidColorBrush x:Key="CreamBrush" Color="{StaticResource Cream}"/>
        <SolidColorBrush x:Key="Pet1Brush" Color="{StaticResource Pet1}"/>
        <SolidColorBrush x:Key="Pet2Brush" Color="{StaticResource Pet2}"/>
        <SolidColorBrush x:Key="Pet3Brush" Color="{StaticResource Pet3}"/>
        <SolidColorBrush x:Key="CheekBrush" Color="{StaticResource PetCheek}"/>
        <SolidColorBrush x:Key="BellyBrush" Color="{StaticResource PetBelly}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#FFFAF0" Opacity="0.95"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="12,10,14,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#66370F"
                                      Opacity="0.22"
                                      BlurRadius="20"
                                      ShadowDepth="6"
                                      Direction="285"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IcoStyle" TargetType="Border">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineBrush}"/>
            <Setter Property="BorderThickness" Value="1.4"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{StaticResource Pet1Brush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HdLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ink2Brush}"/>
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <Style x:Key="TtlStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="ZCOOL KuaiLe, Microsoft YaHei UI, Segoe UI"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="22"/>
        </Style>

        <Style x:Key="SubStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Ink2Brush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="显示/隐藏 TodoFloat" Click="ToggleTodoFloat_Click"/>
            <MenuItem Header="叫醒 Nibble" Click="Wake_Click"/>
            <MenuItem Header="让它睡觉" Click="Sleep_Click"/>
            <Separator/>
            <MenuItem Header="表情">
                <MenuItem Header="happy"   Click="Expr_Happy"/>
                <MenuItem Header="sleepy"  Click="Expr_Sleepy"/>
                <MenuItem Header="excited" Click="Expr_Excited"/>
            </MenuItem>
        </ContextMenu>
    </Window.ContextMenu>

    <!-- Root: a 720×720 transparent stage. Scene + panels are centered inside it. -->
    <Grid x:Name="Root" Background="Transparent">

        <!-- The "scene" — every mouse interaction that should count as
             "interacting with Nibble" must happen inside here. -->
        <Grid x:Name="Scene"
              Width="560" Height="560"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Background="Transparent"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="0.86" ScaleY="0.86"/>
            </Grid.RenderTransform>

            <!-- ── Floating panels (ring of 6) ── -->
            <!-- All six sit on top of each other at scene center; code-behind
                 sets each panel's TranslateTransform to its petal position. -->
            <Grid x:Name="Ring" IsHitTestVisible="True"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Background="Transparent"/>

            <!-- ── Ground shadow ── -->
            <Ellipse x:Name="Ground"
                     Width="140" Height="18"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0,156,0,0"
                     IsHitTestVisible="False"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#38663710" Offset="0"/>
                        <GradientStop Color="#00663710" Offset="0.7"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="1"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="GroundScale" ScaleX="1" ScaleY="1"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- ── Pet (Nibble) ── -->
            <Grid x:Name="Pet"
                  Width="160" Height="160"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Cursor="Hand"
                  Background="Transparent"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform x:Name="PetBob" Y="0"/>
                        <ScaleTransform x:Name="PetSquish" ScaleX="1" ScaleY="1"/>
                        <RotateTransform x:Name="PetTilt" Angle="0"/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <!-- Aura -->
                <Ellipse x:Name="Aura"
                         Width="220" Height="220"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         IsHitTestVisible="False"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#73F4A574" Offset="0"/>
                            <GradientStop Color="#00F4A574" Offset="0.6"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <BlurEffect Radius="6"/>
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="AuraScale" ScaleX="0.95" ScaleY="0.95"/>
                        </TransformGroup>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- Left ear -->
                <Grid Width="34" Height="38"
                      HorizontalAlignment="Center" VerticalAlignment="Top"
                      Margin="-78,12,0,0"
                      RenderTransformOrigin="0.5,1">
                    <Grid.RenderTransform><RotateTransform Angle="-22"/></Grid.RenderTransform>
                    <Ellipse Stroke="{StaticResource OutlineBrush}" StrokeThickness="2.2">
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F4A574" Offset="0"/>
                                <GradientStop Color="#E58748" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="14" Height="18" Fill="#F08770" Opacity="0.7"
                             HorizontalAlignment="Center" VerticalAlignment="Top"
                             Margin="0,6,0,0"/>
                </Grid>

                <!-- Right ear -->
                <Grid Width="34" Height="38"
                      HorizontalAlignment="Center" VerticalAlignment="Top"
                      Margin="78,12,0,0"
                      RenderTransformOrigin="0.5,1">
                    <Grid.RenderTransform><RotateTransform Angle="22"/></Grid.RenderTransform>
                    <Ellipse Stroke="{StaticResource OutlineBrush}" StrokeThickness="2.2">
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F4A574" Offset="0"/>
                                <GradientStop Color="#E58748" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Width="14" Height="18" Fill="#F08770" Opacity="0.7"
                             HorizontalAlignment="Center" VerticalAlignment="Top"
                             Margin="0,6,0,0"/>
                </Grid>

                <!-- Antenna -->
                <Grid HorizontalAlignment="Center" VerticalAlignment="Top"
                      Width="14" Height="34" Margin="0,-2,0,0"
                      IsHitTestVisible="False"
                      RenderTransformOrigin="0.5,1">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="AntennaRot" Angle="-8"/>
                    </Grid.RenderTransform>
                    <Rectangle Width="3" Height="22" Fill="#4A2E18"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"
                               RadiusX="1.5" RadiusY="1.5"/>
                    <Ellipse x:Name="AntennaBulb"
                             Width="14" Height="14"
                             HorizontalAlignment="Center" VerticalAlignment="Top"
                             Margin="0,-3,0,0"
                             Stroke="{StaticResource OutlineBrush}" StrokeThickness="1.5">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFE38A" Offset="0"/>
                                <GradientStop Color="#F4A574" Offset="0.6"/>
                                <GradientStop Color="#D9622A" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="AntennaGlow"
                                              Color="#F4A574" BlurRadius="14"
                                              ShadowDepth="0" Opacity="0.7"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>

                <!-- Body -->
                <Ellipse x:Name="Body"
                         Width="130" Height="140"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Stroke="{StaticResource OutlineBrush}" StrokeThickness="2.5">
                    <Ellipse.Fill>
                        <RadialGradientBrush GradientOrigin="0.3,0.25"
                                             Center="0.3,0.25"
                                             RadiusX="1.2" RadiusY="0.9">
                            <GradientStop Color="#FFD7B0" Offset="0"/>
                            <GradientStop Color="#F4A574" Offset="0.38"/>
                            <GradientStop Color="#E58748" Offset="0.78"/>
                            <GradientStop Color="#C66526" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Belly patch -->
                <Ellipse Width="62" Height="54"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Margin="0,16,0,0"
                         Fill="{StaticResource BellyBrush}"
                         Stroke="#8C4A2E18" StrokeThickness="1.4"/>

                <!-- Face: eyes, blushes, mouth -->
                <Grid Width="90" Height="50"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Margin="0,-8,0,0">

                    <!-- Left eye -->
                    <Grid x:Name="LeftEye" Width="20" Height="24"
                          HorizontalAlignment="Left" VerticalAlignment="Top"
                          Margin="6,6,0,0"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="LeftEyeScale" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Ellipse Fill="#2C1A0E"/>
                        <Ellipse x:Name="LeftEyeSpark" Width="7" Height="7" Fill="#FFF6E6"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                 Margin="4,3,0,0"/>
                        <Ellipse x:Name="LeftEyeSpark2" Width="3" Height="3" Fill="#B3FFF6E6"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                 Margin="0,0,3,4"/>
                    </Grid>

                    <!-- Right eye -->
                    <Grid x:Name="RightEye" Width="20" Height="24"
                          HorizontalAlignment="Right" VerticalAlignment="Top"
                          Margin="0,6,6,0"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="RightEyeScale" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Ellipse Fill="#2C1A0E"/>
                        <Ellipse x:Name="RightEyeSpark" Width="7" Height="7" Fill="#FFF6E6"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                 Margin="4,3,0,0"/>
                        <Ellipse x:Name="RightEyeSpark2" Width="3" Height="3" Fill="#B3FFF6E6"
                                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                 Margin="0,0,3,4"/>
                    </Grid>

                    <!-- Blushes -->
                    <Ellipse x:Name="LeftBlush"
                             Width="14" Height="8" Fill="#99F08770"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="0,28,0,0">
                        <Ellipse.Effect><BlurEffect Radius="0.6"/></Ellipse.Effect>
                    </Ellipse>
                    <Ellipse x:Name="RightBlush"
                             Width="14" Height="8" Fill="#99F08770"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,28,0,0">
                        <Ellipse.Effect><BlurEffect Radius="0.6"/></Ellipse.Effect>
                    </Ellipse>

                    <!-- Mouth -->
                    <Path x:Name="Mouth"
                          HorizontalAlignment="Center" VerticalAlignment="Top"
                          Margin="0,38,0,0"
                          Stroke="#2C1A0E" StrokeThickness="2"
                          Fill="#7A2E1E"
                          StrokeLineJoin="Round"
                          Data="M 0,0 L 14,0 L 14,3 C 14,9 0,9 0,3 Z"/>
                </Grid>

                <!-- Feet -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,6">
                    <Ellipse Width="18" Height="8" Fill="#4A2E18" Margin="0,0,14,0"/>
                    <Ellipse Width="18" Height="8" Fill="#4A2E18"/>
                </StackPanel>

                <!-- Floating pixel sparkles -->
                <Rectangle x:Name="Pix1" Width="6" Height="6" Fill="#F4A574"
                           Stroke="#4A2E18" StrokeThickness="1.2"
                           HorizontalAlignment="Left" VerticalAlignment="Top"
                           Margin="-10,16,0,0"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#F4A574" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                    </Rectangle.Effect>
                    <Rectangle.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="Pix1T"/>
                            <RotateTransform x:Name="Pix1R"/>
                        </TransformGroup>
                    </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle x:Name="Pix2" Width="6" Height="6" Fill="#FFE38A"
                           Stroke="#4A2E18" StrokeThickness="1.2"
                           HorizontalAlignment="Right" VerticalAlignment="Top"
                           Margin="0,40,-18,0"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FFE38A" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                    </Rectangle.Effect>
                    <Rectangle.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="Pix2T"/>
                            <RotateTransform x:Name="Pix2R"/>
                        </TransformGroup>
                    </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle x:Name="Pix3" Width="6" Height="6" Fill="#F08770"
                           Stroke="#4A2E18" StrokeThickness="1.2"
                           HorizontalAlignment="Left" VerticalAlignment="Bottom"
                           Margin="-22,0,0,22"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#F08770" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                    </Rectangle.Effect>
                    <Rectangle.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="Pix3T"/>
                            <RotateTransform x:Name="Pix3R"/>
                        </TransformGroup>
                    </Rectangle.RenderTransform>
                </Rectangle>
                <Rectangle x:Name="Pix4" Width="6" Height="6" Fill="#FFE38A"
                           Stroke="#4A2E18" StrokeThickness="1.2"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Margin="0,0,-10,10"
                           RenderTransformOrigin="0.5,0.5">
                    <Rectangle.Effect>
                        <DropShadowEffect Color="#FFE38A" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                    </Rectangle.Effect>
                    <Rectangle.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="Pix4T"/>
                            <RotateTransform x:Name="Pix4R"/>
                        </TransformGroup>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- Zzz (visible only when sleeping) -->
                <TextBlock x:Name="Zzz"
                           HorizontalAlignment="Center" VerticalAlignment="Top"
                           Margin="50,-8,0,0"
                           FontFamily="ZCOOL KuaiLe, Microsoft YaHei UI, Segoe UI"
                           FontWeight="Bold"
                           Foreground="#8E78B4"
                           Opacity="0"
                           IsHitTestVisible="False"
                           FontSize="22"
                           RenderTransformOrigin="0,1">
                    <Run Text="Z"/><Run Text="z" FontSize="16" Foreground="#998E78B4"/><Run Text="z" FontSize="11" Foreground="#808E78B4"/>
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="ZzzT"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>
        </Grid>

    </Grid>
</Window>
