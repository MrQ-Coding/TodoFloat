<Window x:Class="TodoFloat.Views.DesktopPetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="88"
        Height="82"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        ShowActivated="False">
    <Grid x:Name="PetRoot"
          Cursor="Hand"
          ToolTip="拖动移动，点击显示/隐藏 TodoFloat"
          MouseLeftButtonDown="PetRoot_MouseLeftButtonDown"
          MouseEnter="PetRoot_MouseEnter"
          MouseLeave="PetRoot_MouseLeave">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="PetScale"
                            CenterX="44"
                            CenterY="44"/>
        </Grid.RenderTransform>

        <Ellipse Width="62"
                 Height="14"
                 Fill="#26000000"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Margin="0,0,0,5"/>

        <Canvas Width="78"
                Height="72"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <Path Stroke="#1D4ED8"
                  StrokeThickness="1.6"
                  Data="M17,26 L23,9 L33,20 L41,19 L52,9 L58,27 C65,32 67,44 60,54 C52,66 24,66 15,54 C8,44 10,32 17,26 Z">
                <Path.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6FA7FF" Offset="0"/>
                        <GradientStop Color="#3F73F6" Offset="1"/>
                    </LinearGradientBrush>
                </Path.Fill>
            </Path>
            <Path Fill="#EEF5FF"
                  Data="M24,10 L29,21 L21,21 Z"/>
            <Path Fill="#EEF5FF"
                  Data="M51,10 L47,21 L56,21 Z"/>

            <Ellipse Width="6"
                     Height="7"
                     Fill="#172033"
                     Canvas.Left="29"
                     Canvas.Top="36"/>
            <Ellipse Width="6"
                     Height="7"
                     Fill="#172033"
                     Canvas.Left="46"
                     Canvas.Top="36"/>
            <Ellipse Width="2"
                     Height="2"
                     Fill="#FFFFFF"
                     Canvas.Left="31"
                     Canvas.Top="37"/>
            <Ellipse Width="2"
                     Height="2"
                     Fill="#FFFFFF"
                     Canvas.Left="48"
                     Canvas.Top="37"/>

            <Path Stroke="#172033"
                  StrokeThickness="1.5"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Data="M40,43 L40,46"/>
            <Path Stroke="#172033"
                  StrokeThickness="1.4"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Data="M40,47 C37,50 33,50 31,47"/>
            <Path Stroke="#172033"
                  StrokeThickness="1.4"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Data="M40,47 C43,50 47,50 49,47"/>

            <Ellipse Width="24"
                     Height="24"
                     Fill="#FFFFFF"
                     Stroke="#2F6BFF"
                     StrokeThickness="1.5"
                     Canvas.Left="50"
                     Canvas.Top="45"/>
            <Path Stroke="#22A06B"
                  StrokeThickness="3"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  StrokeLineJoin="Round"
                  Data="M56,57 L62,62 L69,52"/>
        </Canvas>
    </Grid>
</Window>
